# ─── GCP project ────────────────────────────────────────────────────────────
# Optional when a key file is used — derived from the key JSON's project_id.
# Required when authenticating via gcloud ADC (there is no key file to read it from).
GCP_PROJECT_ID=breeze-uat-453414

# ─── Auth: service-account key file OR Application Default Credentials ────────
# Option A — point to a service-account JSON key file:
GCP_KEY_FILE=
# In a pod, mount the SA secret and set the standard var instead — it is picked up
# automatically (precedence: GCP_KEY_FILE → GOOGLE_APPLICATION_CREDENTIALS).
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/key.json
#
# Option B — leave both unset and use Application Default Credentials. For local dev:
#   gcloud auth application-default login
# (On GCP-hosted compute the attached service account is used automatically.)

# ─── Allowlists: the ONLY buckets / load balancers this tool will ever touch ──
# Comma-separated GCS bucket names that appear in the bucket selector.
GCP_BUCKETS=atoms-sdk

# Comma-separated URL maps (load balancers) allowed for cache invalidation.
# Each entry is "urlMapName" or "urlMapName|display.domain" (domain is just a label).
GCP_URL_MAPS=atoms-sdk-lb|sdk.breezesdk.store

# ─── Local backup directory for overwritten config objects ───────────────────
BACKUP_DIR=./backups
